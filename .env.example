# ============================================================
# Conecta 2.0 Portal — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
# Option A: Single connection string (takes precedence)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conecta2

# Option B: Individual connection params
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=conecta2
PG_USER=postgres
PG_PASSWORD=postgres

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiter ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
