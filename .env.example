# Conecta 2.0 Portal — Environment Variables

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=conecta2
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=conecta2-dev-secret

# CORS
CORS_ORIGIN=http://localhost:5173

# Service Ports
BACKEND_CORE_PORT=3000
CATALOG_SERVICE_PORT=3002
SANDBOX_SERVICE_PORT=3003
ANALYTICS_SERVICE_PORT=3004

# Frontend
VITE_API_URL=http://localhost:3000

# Service URLs (used by backend-core proxy)
CATALOG_SERVICE_URL=http://localhost:3002
SANDBOX_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004
